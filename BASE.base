filters:
  not:
    - file.inFolder("0-asset")
    - file.inFolder("0_Excalidraw/font")
views:
  - type: table
    name: Table
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.folder
      - tags
    sort:
      - property: file.ctime
        direction: ASC
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 570
      file.folder: 265
